# =============================================================================
# Bashabari self-hosted backend — environment variables
# Copy this file to `.env` (same folder) and fill in real values.
# NEVER commit the real .env file to git.
# =============================================================================

# ---- Postgres ---------------------------------------------------------------
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ---- JWT (used by GoTrue auth + PostgREST) ----------------------------------
# Generate with:  openssl rand -base64 48
JWT_SECRET=replace-with-48-byte-random-string
# Anon key + service role key are JWTs signed with JWT_SECRET above.
# Generate them once at https://supabase.com/docs/guides/self-hosting/docker#api-keys
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...REPLACE
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...REPLACE

# ---- Public URLs ------------------------------------------------------------
# What the BROWSER will hit. On localhost this is http://localhost:8000
# On a VPS it should be your domain, e.g. https://api.bashabari.example.com
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:5173

# ---- Auth providers ---------------------------------------------------------
# Disable email confirmation while developing locally (set to true in prod)
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_EMAIL_SIGNUP=true

# Google OAuth — leave blank to disable; fill in to enable Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/v1/callback

# ---- Studio (admin UI) ------------------------------------------------------
STUDIO_PORT=3000
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
